# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# Flask — comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Flask — set to "true" only in local development, never in production
FLASK_DEBUG=false

# Next.js dev server — comma-separated LAN IPs allowed for HMR (dev only)
# Example: NEXT_DEV_ORIGINS=192.168.0.103
NEXT_DEV_ORIGINS=
